{
  "name": "cms-foundation",
  "version": "1.0.0",
  "description": "NestJS foundation for the CMS posts API",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest",
